# PostHog MCP Server configuration

# Required: API host (for PostHog Cloud US use https://us.posthog.com, EU: https://eu.posthog.com)
POSTHOG_HOST=https://eu.posthog.com

# Required: Personal API key (phx_*) — create at Account Settings → Personal API Keys
POSTHOG_API_KEY=phx_your_personal_api_key

# Optional: Project API key (phc_*) — only needed for events_capture
POSTHOG_PROJECT_API_KEY=phc_your_project_api_key

# Optional: Default project ID
POSTHOG_PROJECT_ID=1

# Optional: Server identity
MCP_SERVER_NAME=posthog-mcp
MCP_SERVER_VERSION=2.0.0
